        "NEXT_PUBLIC_AUTH_GOOGLE=1",
        "NEXT_PUBLIC_AUTH_MICROSOFT=1",
        "NEXT_PUBLIC_AUTH_GITHUB=1",
        "NEXT_PUBLIC_AUTH_LINKEDIN=1",
        "NEXT_PUBLIC_SUPABASE_URL=https://wdeabrzpgshnouvnfvml.supabase.co",
        "NEXT_PUBLIC_SUPABASE_ANON_KEY=preview-placeholder-anon-key",
        "npm",
        "run",
        "dev",
        "--workspace=apps/web"
      ],
      "port": 3000,
      "autoPort": false
    }
  ]
}