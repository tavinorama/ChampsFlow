{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "web",
      "runtimeExecutable": "npm",
      "runtimeArgs": [
        "run",
        "dev",
        "--workspace=apps/web"
      ],
      "port": 3000,
      "autoPort": false
    },
    {
      "name": "api",
      "runtimeExecutable": "npm",
      "runtimeArgs": [
        "run",
        "dev",
        "--workspace=apps/api"
      ],
      "port": 3001
    },
    {
      "name": "worker",
      "runtimeExecutable": "npm",
      "runtimeArgs": [
