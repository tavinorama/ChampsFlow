# macOS
.DS_Store

# Dependencies
node_modules/

# Build output / generated artifacts
dist/
**/dist/
*.tsbuildinfo

# Next.js
.next/
**/.next/
out/
next-env.d.ts

# Test / coverage output
coverage/
test-results/
playwright-report/

# Turborepo cache
.turbo/

# Editor
.vscode/
.idea/
*.swp
*~

# Local Claude settings (do NOT commit user-specific permissions)
.claude/settings.local.json

# Env / secrets
.env
.env.*
!.env.example
*.pem
*.key

# Project artifacts (generated per project, not part of scaffolding)
docs/01-discovery.md
docs/01-discovery-review.md
docs/02-prd.md
docs/02-prd-review.md
docs/03-architecture.md
docs/03-architecture-review.md
docs/04-ux.md
docs/04-ux-review.md
docs/05-impl-log.md
docs/05-review-*.md
docs/06-qa.md
docs/06-qa-review.md
docs/07-deploy.md
docs/07-deploy-review.md

# Project meta state (filled per-project; keep STATE.md in scaffolding as template)
# STATE.md is committed as a template — agents fill it in per project clone.

# Compliance artifacts (generated per project)
docs/compliance/model-cards/

# Marketing / sales / support artifacts (generated per project)
# EXCEPTION: lead-magnet SOURCES are product source-of-truth (the paid PDFs in
# apps/web/public/downloads are built from them) — they must live in git.
# (`docs/marketing/*` instead of `docs/marketing/` so the re-include works —
# git cannot re-include below an excluded directory.)
docs/marketing/*
!docs/marketing/lead-magnets/
docs/sales/
docs/support/

# Learning docs (institutional knowledge — MUST be committed, never ignored)
# docs/learning/ is intentionally NOT listed here so it is always tracked by git

# Compiled artifacts must never live in src/ (they shadow .ts in vitest)
packages/*/src/**/*.js
packages/*/src/**/*.js.map
packages/*/src/**/*.d.ts
apps/*/src/**/*.js
apps/*/src/**/*.js.map
