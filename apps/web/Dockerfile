# syntax=docker/dockerfile:1.7
#
# Organic Posts — Web (Next.js 15) production image
# ================================================
# Multi-stage build for an npm workspaces monorepo.
#
# Stages:
#   1. deps     — install workspace deps (cached layer)
#   2. builder  — build the Next.js standalone bundle
#   3. runner   — minimal runtime (~150MB) with a non-root user
#
# Build from the REPO ROOT:
#   docker build -f apps/web/Dockerfile -t organicposts/web .
# Run:
#   docker run -p 3000:3000 organicposts/web
#
# The build is fully offline-capable once layers are cached.

# ───────────────────────────────────────────── 1. deps
FROM node:20-alpine AS deps
RUN apk add --no-cache libc6-compat
WORKDIR /app

# Copy ONLY package manifests first to maximize layer caching.
# A code change should never invalidate the npm install layer.
COPY package.json package-lock.json* turbo.json* ./
COPY apps/web/package.json ./apps/web/package.json
COPY packages/shared/package.json ./packages/shared/package.json
# Best-effort copies for workspaces that may not exist in shallower checkouts.
COPY packages ./packages

# Install with --omit=dev disabled here — we need build-time deps (typescript,
# tailwind, etc.). The runner stage installs only prod deps.
# npm hoists workspace deps to the ROOT node_modules, so per-workspace
# node_modules dirs may not exist. Create them so the builder's
# `COPY --from=deps /app/apps/web/node_modules` never fails on a missing path.
RUN npm ci --workspaces --include-workspace-root --legacy-peer-deps \
 && mkdir -p apps/web/node_modules packages/shared/node_modules

# ───────────────────────────────────────────── 2. builder
FROM node:20-alpine AS builder
WORKDIR /app
ENV NEXT_TELEMETRY_DISABLED=1 \
    NODE_ENV=production \
    NEXT_OUTPUT=standalone

COPY --from=deps /app/node_modules ./node_modules
COPY --from=deps /app/apps/web/node_modules ./apps/web/node_modules
COPY --from=deps /app/packages ./packages
COPY . .

# Build args baked into the standalone output. Next evaluates next.config.js
# rewrites at BUILD time, so INTERNAL_API_URL must be present here (not just at
# runtime). NEXT_PUBLIC_* are also build-time-inlined for the browser bundle.
ARG INTERNAL_API_URL=http://localhost:3001
ARG NEXT_PUBLIC_SUPABASE_URL=
ARG NEXT_PUBLIC_SUPABASE_ANON_KEY=
ARG NEXT_PUBLIC_AUTH_GOOGLE=
ARG NEXT_PUBLIC_AUTH_MICROSOFT=
ARG NEXT_PUBLIC_AUTH_GITHUB=
ARG NEXT_PUBLIC_AUTH_LINKEDIN=
ENV INTERNAL_API_URL=$INTERNAL_API_URL \
    NEXT_PUBLIC_SUPABASE_URL=$NEXT_PUBLIC_SUPABASE_URL \
    NEXT_PUBLIC_SUPABASE_ANON_KEY=$NEXT_PUBLIC_SUPABASE_ANON_KEY \
    NEXT_PUBLIC_AUTH_GOOGLE=$NEXT_PUBLIC_AUTH_GOOGLE \
    NEXT_PUBLIC_AUTH_MICROSOFT=$NEXT_PUBLIC_AUTH_MICROSOFT \
    NEXT_PUBLIC_AUTH_GITHUB=$NEXT_PUBLIC_AUTH_GITHUB \
    NEXT_PUBLIC_AUTH_LINKEDIN=$NEXT_PUBLIC_AUTH_LINKEDIN

# Next.js standalone output lands in apps/web/.next/standalone
RUN npm run build --workspace=@organic-posts/web

# ───────────────────────────────────────────── 3. runner
FROM node:20-alpine AS runner
WORKDIR /app
ENV NODE_ENV=production \
    NEXT_TELEMETRY_DISABLED=1 \
    PORT=3000 \
    HOSTNAME=0.0.0.0

# Non-root user — defence in depth
RUN addgroup --system --gid 1001 nodejs && \
    adduser  --system --uid 1001 --ingroup nodejs nextjs

# Copy the standalone server + static assets only.
# This is what makes the image small (~150MB instead of ~1GB).
COPY --from=builder --chown=nextjs:nodejs /app/apps/web/.next/standalone ./
COPY --from=builder --chown=nextjs:nodejs /app/apps/web/.next/static ./apps/web/.next/static
COPY --from=builder --chown=nextjs:nodejs /app/apps/web/public ./apps/web/public

USER nextjs
EXPOSE 3000

# Health check — Next.js answers / quickly when ready.
# Use 127.0.0.1 (not "localhost"): inside the container wget resolves localhost
# to IPv6 ::1, but the Next standalone server listens on IPv4 0.0.0.0, so a
# localhost probe gets connection-refused and the container is wrongly marked
# unhealthy (→ orchestrator restart loops). 127.0.0.1 forces the IPv4 loopback.
HEALTHCHECK --interval=30s --timeout=5s --start-period=15s --retries=3 \
  CMD wget --no-verbose --tries=1 --spider http://127.0.0.1:3000/ || exit 1

# server.js is auto-generated by Next.js standalone output.
CMD ["node", "apps/web/server.js"]
