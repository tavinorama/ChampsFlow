# Organic Posts — Environment Variable Template
# Copy this file to .env.local for local development.
# NEVER commit a file containing real secret values.
# All production secrets are stored in Railway environment variables per service.
# See docs/07-deploy.md Section 5 for the full secrets management policy.
#
# Legend:
#   [api]     — required for the API server (apps/api)
#   [worker]  — required for the job worker (apps/worker)
#   [web]     — required for the Next.js frontend (apps/web)
#   [all]     — required by all services
#   [EU only] — only needed when DEFAULT_TENANT_REGION=eu (AWS Bedrock path)
#   [US only] — only needed when DEFAULT_TENANT_REGION=us (direct Anthropic API path)

# ---------------------------------------------------------------------------
# Node / runtime
# ---------------------------------------------------------------------------
NODE_ENV=development              # [all]  development | production | test
PORT=3000                         # [api]  Railway injects this automatically in production

# ---------------------------------------------------------------------------
# Data residency routing
# ---------------------------------------------------------------------------
DEFAULT_TENANT_REGION=eu          # [all]  eu | us — determines LLM routing + default Supabase project

# ---------------------------------------------------------------------------
# Database — Supabase Postgres
# Use the Supabase "Connection Pooling" URL (pgBouncer) for API/worker.
# Use the direct connection string for migrations (npm run db:migrate).
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:[password]@[host]:5432/postgres    # [api][worker]

# Runtime RLS enforcement role. The API AND the worker drop into this
# NON-superuser role per query (set_config('role', …)) so FORCE ROW LEVEL
# SECURITY actually applies. Created by the initial migration; the login role
# above must be a member of it (granted in migration 20260618000001). Leave unset
# to use the default. Both the API and the worker refuse to boot if this role is
# missing or is a superuser/BYPASSRLS role.
APP_DB_ROLE=app_user                                                  # [api][worker]

# ---------------------------------------------------------------------------
# Redis — Upstash
# ---------------------------------------------------------------------------
REDIS_URL=redis://:[password]@[host]:[port]                           # [api][worker]

# ---------------------------------------------------------------------------
# Supabase Auth + Admin
# ---------------------------------------------------------------------------
SUPABASE_URL=https://[project-ref].supabase.co                        # [api]
SUPABASE_SERVICE_ROLE_KEY=eyJ...                                       # [api][worker] — server-side only; NEVER in web
SUPABASE_JWKS_URL=https://[project-ref].supabase.co/auth/v1/.well-known/jwks.json  # [api]

# ---------------------------------------------------------------------------
# OAuth token field-level encryption (AES-256-GCM)
# Must be a 64-character hex string (32 bytes). Generate with:
#   openssl rand -hex 32
# Same value required in both api and worker.
# Rotation cadence: 12 months. See docs/runbooks/key-rotation.md.
# ---------------------------------------------------------------------------
OAUTH_TOKEN_KEY=replace_with_64_char_hex_string                       # [api][worker]

# ---------------------------------------------------------------------------
# Anthropic API — US tenants (direct API path)
# NOT needed when DEFAULT_TENANT_REGION=eu (Bedrock path is used instead).
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...                                           # [api][US only]

# ---------------------------------------------------------------------------
# AWS Bedrock — EU tenants
# IAM credentials scoped to bedrock:InvokeModel on eu-central-1 only.
# NOT needed when DEFAULT_TENANT_REGION=us.
# ---------------------------------------------------------------------------
AWS_BEDROCK_REGION=eu-central-1                                        # [api][EU only]
AWS_ACCESS_KEY_ID=AKIA...                                              # [api][EU only]
AWS_SECRET_ACCESS_KEY=replace_with_aws_secret                          # [api][EU only]

# ---------------------------------------------------------------------------
# CORS — Web origin allowed for API requests
# ---------------------------------------------------------------------------
WEB_ORIGIN=http://localhost:3000                                       # [api]

# ---------------------------------------------------------------------------
# Web → API proxy. INTERNAL_API_URL must be set as a Next.js BUILD ARG (not just
# runtime) — the /api/:path* rewrite is baked at build time. In prod set it to
# the API service's internal URL (e.g. https://<api>.railway.internal:3001).
# ---------------------------------------------------------------------------
INTERNAL_API_URL=http://localhost:3001                                 # [web build-arg]

# ---------------------------------------------------------------------------
# Stripe billing
# Use test mode keys (sk_test_...) for dev and staging.
# Use live mode keys (sk_live_...) for production only.
# ---------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_replace_me                                   # [api]
STRIPE_WEBHOOK_SECRET=whsec_replace_me                                 # [api]
# Monthly subscription price IDs (full price — no founder discount on monthly).
STRIPE_PRICE_ID_GROWTH=price_replace_me                                # [api]  Growth $99/mo
STRIPE_PRICE_ID_AGENCY=price_replace_me                                # [api]  Agency $149/mo
# Annual subscription price IDs (one yearly charge). REQUIRED to offer the
# founder discount, which is ANNUAL-ONLY.
STRIPE_PRICE_ID_GROWTH_ANNUAL=price_replace_me                         # [api]  Growth annual (12×$99 = $1,188)
STRIPE_PRICE_ID_AGENCY_ANNUAL=price_replace_me                         # [api]  Agency annual (12×$149 = $1,788)
# Founder discount coupon — create a 30%-off coupon in Stripe and put its ID here.
# Applied ONLY to annual checkouts (founder discount is annual-only). If unset,
# no founder discount is applied and annual checkout falls back to list price.
STRIPE_FOUNDER_COUPON_ID=                                              # [api]  e.g. FOUNDER30 (30% off, annual only)
# One-time price for "The Get-Cited Kit" ($29 tripwire).
STRIPE_PRICE_ID_KIT=price_replace_me                                   # [api]

# ---------------------------------------------------------------------------
# Email — Resend
# EU infrastructure must be selected in Resend account settings.
# Verify the trustindexai.com sender domain in Resend before go-live.
# Code defaults are now all @trustindexai.com (standardized 2026-06-13).
# ---------------------------------------------------------------------------
RESEND_API_KEY=re_replace_me                                           # [api][worker]
EMAIL_FROM=noreply@trustindexai.com                                    # transactional sender (login, DSR)
WAITLIST_FROM_EMAIL=hello@trustindexai.com                             # waitlist confirmations
RESEND_FROM_ADDRESS=privacy@trustindexai.com                           # CCPA notices
DSR_OPERATIONS_EMAIL=dpo@trustindexai.com                              # where DSR/privacy requests are routed
# Inboxes to provision (receive) via Cloudflare Email Routing:
#   hello@trustindexai.com    — general / sales / LinkedIn contact
#   dpo@trustindexai.com      — privacy / Encarregado (LGPD DPO)
#   support@trustindexai.com  — customer support
#   privacy@trustindexai.com  — DSR/privacy (can alias to dpo@)

# ---------------------------------------------------------------------------
# Social platform OAuth credentials
# See docs/07-deploy.md Section 11 for registration steps.
# ---------------------------------------------------------------------------
LINKEDIN_CLIENT_ID=replace_me                                          # [api]
LINKEDIN_CLIENT_SECRET=replace_me                                      # [api]

META_APP_ID=replace_me                                                 # [api]
META_APP_SECRET=replace_me                                             # [api]

# ---------------------------------------------------------------------------
# Observability — Axiom
# Use separate datasets per environment (dev/staging/prod-eu/prod-us).
# ---------------------------------------------------------------------------
AXIOM_TOKEN=xaat-replace_me                                            # [all]
AXIOM_DATASET=organicposts-dev                                         # [all]  e.g. organicposts-eu-prod, organicposts-us-prod

# ---------------------------------------------------------------------------
# DPA versioning
# The current version string embedded in the DPA modal acknowledgment.
# ---------------------------------------------------------------------------
DPA_CURRENT_VERSION=1.0                                                # [api][web]
